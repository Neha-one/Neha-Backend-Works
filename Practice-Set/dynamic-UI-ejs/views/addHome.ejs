<%- include('partials/head') %>

</head>

<body>
  <%- include('partials/navbar') %>

  <main class="min-h-screen flex items-center justify-center bg-gray-100">
    <div class="w-full max-w-md bg-white p-8 rounded-xl shadow-lg">
      <h1 class="text-3xl font-bold text-center text-red-500 mb-6">
        Register your Home
      </h1>
  
      <form action="/host/add-home" method="POST" class="space-y-4">
  
        <input type="text" name="houseName" placeholder="Enter house name"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-400">
  
        <input type="number" name="housePrice" placeholder="Enter house price"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-400">
  
        <input type="text" name="houseLocation" placeholder="Enter location"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-400">
  
        <input type="number" name="houseRating" placeholder="Enter rating"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-400">
  
        <input type="text" name="houseImage" placeholder="Enter image Name"
          class="w-full border border-gray-300 rounded-lg px-4 py-2 focus:outline-none focus:ring-2 focus:ring-red-400">
  
        <button type="submit"
          class="w-full bg-red-500 text-white py-2 rounded-lg font-semibold hover:bg-red-600 transition duration-300">
          Register Home
        </button>
  
      </form>
    </div>
  </main>
</body>

</html>