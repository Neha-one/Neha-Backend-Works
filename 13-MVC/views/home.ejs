<%- include('partials/head') %>

  </head>

  <body class="bg-gray-100">

    <%- include('partials/navbar') %>

      <main class="max-w-2xl mx-auto mt-10 bg-white p-8 rounded-xl shadow-lg">
        <div>
          <h1 class="text-3xl font-bold text-center text-red-500 mb-3">
            Registered Homes
          </h1>
        </div>
        <ul class=" flex gap-4">
          <% registeredHomes.forEach(home=> { %>

            <li
              class="bg-gray-50 border w-fit border-gray-200 rounded-xl p-5 shadow-sm hover:shadow-md transition duration-300">
              <div>
                <img src="/images/<%= home.houseImage %>" alt="">
              </div>
              <div class="flex justify-between items-center ">
                <h2 class="text-xl font-bold text-gray-800">
                  <%= home.houseName %>
                </h2>
              </div>
                <div class="mt-3 space-y-1 text-gray-700">
                  <p> <span class="font-medium">
                      <%= home.houseLocation %>
                    </span>
                  </p>
                </div>
              <div>
                <span class="bg-green-100 text-green-700 px-3 py-1 rounded-full text-sm font-medium">
                  Rs<%= home.housePrice %> / night
                </span>
               <span class="font-medium">
                    ⭐<%= home.houseRating %> (5)
                  </span>
              </div>
            </li>

            <% }) %>
        </ul>
      </main>

  </body>

  </html>